#!/usr/bin/env bash

# Monitor setup
# Note: I added a small sleep because sometimes Hyprland needs a beat to
# adjust the bitdepth before the game tries to grab the resolution.
PRE_COMMAND="hyprctl keyword monitor DP-1,preferred,0x0,1,bitdepth,10,cm,hdr"
POST_COMMAND="hyprctl keyword monitor DP-1,preferred,0x0,1,bitdepth,10"

# Initialize an array for the command
cmd_args=()

# Split the args at --
while [[ $# -gt 0 ]]; do
  if [ "$1" == "--" ]; then
    shift
    # Load everything after -- into our array
    cmd_args+=("$@")
    break
  fi
  shift
done

# Cleanup function
post_command() {
  echo "Restoring monitor settings..."
  eval "$POST_COMMAND"
}

# Ensure the monitor resets even if the game crashes
trap post_command EXIT

# Apply HDR monitor settings
eval "$PRE_COMMAND"
sleep 0.5

# Launch the game
# I removed PROTON_ENABLE_WAYLAND=1 by default because it breaks many games.
# If a specific game needs it, add it to Steam launch options instead.
ENABLE_HDR_WSI=1 DXVK_HDR=1 "${cmd_args[@]}"
